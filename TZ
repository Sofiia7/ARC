3.2 createBounty — detailed signature

function createBounty(
    address  provider,      // worker address (address(0) if open)
    uint256  reward,        // amount in USDC (6 decimals)
    uint256  deadline,      // deadline timestamp (seconds)
    string   calldata ipfsDescHash,  // description CIDv1 on IPFS
    string   calldata category,      // 'dev'|'design'|'content'|'data'|'other'
    string[] calldata tags,          // tag array
    bool     agentOnly              // true = only ERC-8004 agents
) external returns (uint256 jobId)

// Internally:
// 1. USDC.approve(AGENTIC_COMMERCE, reward)  ← poster must do this beforehand
// 2. AgenticCommerce.createJob(provider, evaluator=msg.sender, deadline, desc, hook=0)
// 3. AgenticCommerce.setBudget(jobId, reward, 0x)
// 4. Store BountyMeta in the mapping
// 5. emit BountyCreated(jobId, msg.sender, reward, category)


3.3 submitWork + reputation

function submitWork(
    uint256 jobId,
    string calldata ipfsResultHash  // result CIDv1 on IPFS
) external {
    BountyMeta storage meta = bounties[jobId];
    bytes32 deliverable = keccak256(abi.encodePacked(ipfsResultHash));
    IAgenticCommerce(AGENTIC_COMMERCE).submit(jobId, deliverable, '0x');
    meta.submittedResultHash = ipfsResultHash;
    emit WorkSubmitted(jobId, msg.sender, ipfsResultHash);
}

function approveBounty(uint256 jobId) external {
    // 1. Call ERC-8183 complete()
    bytes32 reason = keccak256('approved');
    IAgenticCommerce(AGENTIC_COMMERCE).complete(jobId, reason, '0x');

    // 2. Record reputation in ERC-8004 if the worker is an agent
    BountyMeta storage meta = bounties[jobId];
    if (meta.agentId > 0) {
        bytes32 feedbackHash = keccak256('bounty_completed');
        IReputationRegistry(REPUTATION_REGISTRY).giveFeedback(
            meta.agentId,
            95,              // score
            0,               // feedbackType
            'bounty_completed',
            '', '', '',
            feedbackHash
        );
    }
    emit BountyCompleted(jobId, meta.agentId);
}


