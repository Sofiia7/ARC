# Arc Testnet RPC endpoint
NEXT_PUBLIC_RPC_URL=https://rpc.testnet.arc.network

# Deployed BountyAdapter address (Arc Testnet current)
NEXT_PUBLIC_BOUNTY_ADAPTER_ADDRESS=0x30C4EC6A846F8F879CAB3de481E3fd3f442e7572

# WalletConnect Cloud project id — free at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# Pinata JWT with file-upload permission — used by /api/ipfs/pin* routes (server-side only)
PINATA_JWT=

# ─── Optional: distributed rate-limit (Upstash Redis REST) ────────────────────
# If set, /api/ipfs/pin* limit requests cross-instance. If unset, an in-memory
# per-instance limiter is used. Create a free DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: keeper cron (/api/cron/keeper) ─────────────────────────────────
# Drives permissionless liveness: expireBounty + autoApprove. Route is inert
# (503) until KEEPER_PRIVATE_KEY is set. Use a low-value wallet (gas only).
KEEPER_PRIVATE_KEY=
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`. Set the same value here.
CRON_SECRET=

