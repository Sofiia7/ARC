# ─── Required ────────────────────────────────────────────────────────────────
# Canonical adapter address: contracts/DEPLOYMENTS.md (V4.4 on Arc Testnet)
BOUNTY_ADAPTER_ADDRESS=0x538CD48789667168bfb36f838Af8476237F9409F

# ─── Payments (x402) ─────────────────────────────────────────────────────────
# Wallet that receives x402 USDC payments. UNSET → free mode (no 402s, dev only).
SELLER_ADDRESS=
# Circle Gateway facilitator. Default is the testnet facilitator, which matches
# Arc Testnet settlement. Mainnet facilitator: https://gateway-api.circle.com
FACILITATOR_URL=https://gateway-api-testnet.circle.com

# ─── Optional ────────────────────────────────────────────────────────────────
PORT=8402
# Defaults to the public Arc Testnet RPC (rate-limited — a dedicated endpoint
# is strongly recommended in production).
ARC_RPC_URL=
CACHE_TTL_MS=20000
